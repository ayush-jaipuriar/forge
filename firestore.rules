rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDefaultDoc(docId) {
      return docId == 'default';
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.uid == userId;
      allow update: if isOwner(userId) && request.resource.data.uid == userId;
      allow delete: if false;

      match /settings/{settingsId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isDefaultDoc(settingsId)
          && request.resource.data.id == 'default';
        allow delete: if false;
      }

      match /dayInstances/{dayId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /analyticsSnapshots/{snapshotId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /projections/{projectionId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isDefaultDoc(projectionId)
          && request.resource.data.id == 'default';
        allow delete: if false;
      }

      match /streaks/{streakId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isDefaultDoc(streakId)
          && request.resource.data.id == 'default';
        allow delete: if false;
      }

      match /missions/{missionId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /insights/{insightId} {
        allow read, create, update: if isOwner(userId);
        allow delete: if false;
      }

      match /analyticsMetadata/{metadataId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId)
          && isDefaultDoc(metadataId)
          && request.resource.data.id == 'default';
        allow delete: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
