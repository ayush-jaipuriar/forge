{
  "name": "forge-functions",
  "private": true,
  "type": "module",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --platform node --target node20 --out-dir lib --clean --sourcemap --external firebase-admin --external firebase-functions",
    "lint": "eslint \"src/**/*.ts\"",
    "serve": "firebase emulators:start --only functions",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "firebase-admin": "^13.6.0",
    "firebase-functions": "^6.6.0"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
